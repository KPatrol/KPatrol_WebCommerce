# K-Patrol Web Commerce Environment Variables
# Copy this file to .env.local and fill in the values

# ─── Public site config ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://kpatrol.khoavd.online
NEXT_PUBLIC_CONTACT_EMAIL=contact@kpatrol.khoavd.online

# ─── Admin panel auth ─────────────────────────────────────────────────────────
# Plaintext password compared at /api/admin/auth. Use a long random string in prod.
ADMIN_PASSWORD=change-me-in-production
# Opaque token written to the admin_session cookie. Generate with: openssl rand -hex 32
ADMIN_SESSION_TOKEN=change-me-to-a-random-hex-string

# ─── Transactional email (Resend) ─────────────────────────────────────────────
# Both must be set for inquiry → admin notifications. Leave blank to disable.
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=

# ─── Analytics (optional - set in Netlify dashboard) ──────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
